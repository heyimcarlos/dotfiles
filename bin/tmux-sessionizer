#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 1 ]]; then
    selected=$1
else
    roots=("$HOME" "$HOME/repos" "$HOME/thoughts" "$HOME/Documents" "$HOME/.config")
    existing_roots=()
    for root in "${roots[@]}"; do
        [[ -d "$root" ]] && existing_roots+=("$root")
    done

    selected=$(
        find "${existing_roots[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
            | sort -u \
            | fzf --prompt='Select a directory: '
    )
fi

if [[ -z ${selected:-} ]]; then
    exit 0
fi

# tmux session names cannot contain ':' and are painful with spaces/punctuation.
selected_name=$(basename "$selected" | tr -c '[:alnum:]_-' '_' | sed 's/_\+$//; s/^_\+//')
if [[ -z $selected_name ]]; then
    selected_name=sessionizer
fi

tmux_running=$(tmux ls 2>/dev/null || true)

if [[ -z ${TMUX:-} && -z $tmux_running ]]; then
    exec tmux new-session -s "$selected_name" -c "$selected"
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"
